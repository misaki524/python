## chapter5.rpy — 第5章「午前4時 — 真相」

label chapter5:

    $ current_time = "AM 4:00"

    call update_clue_count

    # ルート判定
    if underground:
        jump chapter5_underground
    elif went_outside:
        jump chapter5_outside
    elif called_sato:
        jump chapter5_sato
    else:
        # barricadeルートは第4章でエンディングに直行済み
        # ここには来ないはず。安全策で。
        jump ending_normal

# ============================================================
# ルートA: 地下倉庫ルート
# ============================================================

label chapter5_underground:

    scene bg_underground

    "もう一人の自分が——目の前に立っている。"

    "同じ顔。同じ身長。同じエプロン。"
    "だが、その目だけが違う。"
    "底のない暗闇。深淵のような黒い瞳。"

    "もう一人の自分が、口を開いた。"

    "「ずっと待っていた。」"

    p "お前は……何だ？"

    "「お前だよ。境界の向こう側のお前だ。」"

    "「この店は境界の上に建っている。」"
    "「毎年この時期に、向こう側とこちら側が重なる。」"
    "「俺は向こう側で、ずっとお前を見ていた。」"

    p "向こう側……？"

    "「こちら側に来たい。お前の場所に、お前の代わりに立ちたい。」"

    "「受け入れてくれないか。」"

    menu:
        "受け入れる":
            $ accepted_doppelganger = True
            jump ending_swap

        "拒絶する":
            $ accepted_doppelganger = False

            p "断る。ここは俺の場所だ。"

            "もう一人の自分が、悲しそうに微笑んだ。"

            "「そうか。……それなら、朝が来るまで耐えてくれ。」"

            "もう一人の自分の姿が薄れていく。"

            "「ただし——あの子のことは、頼む。」"

            p "あの子……ミサキちゃんのことか？"

            "返事はなかった。影は消え、地下倉庫には自分一人が残された。"

            "その瞬間——扉の鍵が、カチリと音を立てて開いた。"

            # 手がかりチェック → 儀式or生還
            if found_diary and found_camera and found_girl_clue:
                "地下から店内に戻ると——そこに少女が立っていた。"

                scene bg_store_inside_dark with dissolve
                show chara_girl at center with dissolve

                misaki "お兄さん。全部知ったんだね。"

                p "ミサキちゃん……君は30年前に——"

                misaki "うん。もう、分かってる。"

                "少女の目に涙が浮かんでいた。"

                misaki "助けて。わたしを、ここから出して。"

                jump chapter5_ritual

            else:
                "地下から店内に戻った。"
                "蛍光灯が安定し始めている。"
                "夜が明けに向かっている。"
                jump ending_survivor

# ============================================================
# ルートC: 霧の外ルート（found_girl_clue=Trueの場合のみ到達）
# ============================================================

label chapter5_outside:

    scene bg_fog with dissolve

    "少女に導かれ、霧の中を歩く。"

    show chara_girl at center

    misaki "もうすぐだよ。"

    "少女の足取りは迷いがない。"
    "霧の中に、何か見える——"

    "古びた家の輪郭。"
    "もう存在しないはずの——30年前の小さな家。"

    p "これは……"

    misaki "わたしの家。"

    "霧の中に浮かぶ幻影。だが少女には確かに見えている。"

    misaki "ここでお母さんと暮らしてたの。"
    misaki "ある日、知らない場所に来ちゃって……ずっと、帰れなかった。"

    p "ミサキちゃん……"

    misaki "お兄さんは、わたしのこと分かってくれたよね。"
    misaki "わたしが何か、分かってくれた。"

    "少女がこちらを見上げた。"

    hide chara_girl

    if found_diary and found_camera and found_girl_clue:
        "すべての真相が繋がった。"
        "30年前の失踪事件。境界。残留思念。"
        "田中の日記に書かれていた方法——"

        jump chapter5_ritual

    else:
        "だが、自分には全貌が見えていない。"
        "少女を助ける方法も、この霧を晴らす方法も分からない。"

        misaki "いいの。会えただけで……嬉しかった。"

        "少女の姿が薄れていく。"

        misaki "朝が来れば、お兄さんは帰れるよ。"

        "光が——東の方角から差し始めた。"
        "霧がゆっくりと晴れていく。"

        jump ending_survivor

# ============================================================
# ルートD: 佐藤合流ルート
# ============================================================

label chapter5_sato:

    scene bg_store_inside_dark with dissolve

    $ current_time = "AM 4:00"

    "佐藤と二人、カウンターの中にいる。"

    if showed_diary_to_sato:
        sato "田中の日記をもう一度読もう。何か見落としてるかもしれない。"

        "佐藤が日記の続きを読み始める。"

        $ diary_pages_read += 1

        sato "ここ、見ろよ。"

        "{i}10月28日{/i}"
        "{i}分かった。あの子——ミサキを助ける方法がある。{/i}"
        "{i}地下に行く。あの子を助けなきゃ。{/i}"
        "{i}佐藤、もし俺が戻ってこなかったら——ごめん。{/i}"

        sato "……田中。"

        "佐藤が目を伏せた。"

        sato "あいつは、最後まで誰かを助けようとしてたんだな。"

        "不意に——店の奥から声が聞こえた。"

        "遠い、かすれた声。だが確かに——"

        "「こっちに来るな。」"

        sato "——っ！　田中！？"

        p "今の声……"

        "「でも……あの子を頼む。」"

        "声はそれ以上続かなかった。"
        "だが——田中は生きている。どこかで。"

        sato "田中……お前、まだ……"

        "佐藤の目に涙が浮かんでいた。"

        # 儀式条件チェック
        if found_diary and found_girl_clue and found_camera:
            sato "……日記に書いてある方法、試してみないか。"
            sato "あの子を——ミサキを助ける儀式。"
            sato "田中も、それをやろうとしてたんだ。"

            jump chapter5_ritual
        else:
            sato "俺たちに今できることは……田中の意志を継ぐことだ。"
            sato "あの子を助ける方法を、いつか必ず見つけよう。"

            "夜が——明け始めていた。"

            jump ending_predecessor

    else:
        sato "なんとか朝まで耐えるしかないな。"

        "佐藤がいるだけで、少しだけ安心できた。"
        "二人でカウンターの中に陣取り、朝を待つ。"

        "異変は続いている。棚から物が落ち、蛍光灯が瞬く。"
        "だが——二人なら耐えられる。"

        $ current_time = "AM 4:30"

        "時計が進んでいく。4時30分。"

        $ current_time = "AM 4:55"

        "4時55分。"

        "蛍光灯が安定し始めた。"
        "冷蔵庫の異音が収まる。"

        sato "……なんか、静かになってきたな。"

        "窓の外を見る。霧が——薄くなっている。"

        sato "朝だ。夜が明ける。"

        if clue_count >= 2:
            jump ending_survivor
        else:
            jump ending_normal

# ============================================================
# 儀式ルート（特殊条件: diary + camera + girl_clue）
# ============================================================

label chapter5_ritual:

    scene bg_store_inside_dark with dissolve
    $ current_time = "AM 4:30"

    "全ての手がかりが一つに繋がった。"

    "30年前、この土地にあった家で少女ミサキが事故死した。"
    "その魂は土地に縛られ、毎年10月に「境界」を生み出す。"
    "スーツの男は当時の捜査官の残留思念。"
    "フードの人物は境界から滲み出た存在。"

    "そして——田中の日記に記されていた方法。"

    p "ミサキちゃんの魂を解放すれば、境界は閉じる。"

    if called_sato:
        sato "やろう。田中にもできなかったことを——俺たちで。"

    show chara_girl at center with dissolve

    misaki "お兄さん……。"

    p "ミサキちゃん。君を家に帰すよ。"

    misaki "……本当に？"

    p "約束する。"

    "日記に書かれた通りに——"
    "地下から持ち出した30年前の遺品を、カウンターの上に並べる。"
    "少女の写真。古い手紙。そして——"

    "少女が探していた「落とし物」。"
    "それは——母親からもらった小さなお守りだった。"
    "地下の木箱の底に、ずっと眠っていた。"

    misaki "……これ。おかあさんの。"

    "少女がお守りを手に取る。"
    "その瞬間——店内が、白い光に包まれた。"

    menu:
        "儀式を完遂する":
            $ ritual_success = True

            "少女の身体が光に包まれていく。"

            show chara_girl_smile at center with dissolve

            misaki "ありがとう。ありがとう、お兄さん。"

            misaki "もう大丈夫。わたし、帰れるよ。"

            "少女が微笑んだ。"
            "初めて見る、穏やかな笑顔だった。"

            "光がさらに強くなり——"

            "少女の姿が、光の中に溶けていく。"

            misaki "おかあさんのところに……帰るね。"

            hide chara_girl_smile with dissolve

            "……。"

            "光が収まった。"

            "店内には、自分だけが残されていた。"

            if called_sato:
                sato "……行ったか。"
                sato "あの子、笑ってたな。"
                p "ああ……笑ってた。"

            jump ending_dawn

        "儀式を中断する":
            $ ritual_success = False

            p "……ごめん。これが正しいのか、確信が持てない。"

            misaki "……いいの。無理しないで。"

            "少女がお守りを胸に抱きしめた。"

            misaki "いつか……いつか迎えに来てくれたら嬉しいな。"

            hide chara_girl with dissolve

            "少女の姿が薄れ、消えていった。"

            "蛍光灯が安定し始める。霧が晴れていく。"

            jump ending_survivor
